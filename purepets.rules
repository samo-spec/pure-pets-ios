rules_version = '2';

// ============================================================================
//  Pure Pets — Firestore Security Rules
//  Generated: 2026-03-21
//
//  Collection Map (deep-scanned from iOS + Cloud Functions codebase):
//
//  TOP-LEVEL COLLECTIONS
//  ─────────────────────
//  UsersCol/{uid}                          — User profiles
//    ├─ permissions/{permKey}              — Canonical permission docs
//    ├─ PermisstionsCol/{permKey}          — Legacy permissions (typo variant)
//    ├─ PermissionsCol/{permKey}           — Legacy permissions (alt variant)
//    ├─ Addresses/{addressId}             — Shipping addresses
//    ├─ paymentInstruments/{instrId}       — Saved payment methods
//    ├─ inbox/{notifId}                   — Admin push inbox
//    ├─ favoritesAds/{adId}               — Favorited pet ads
//    ├─ favoritesAccessories/{accessId}   — Favorited accessories
//    ├─ favoritesServices/{serviceId}     — Favorited services
//    ├─ favoritesVets/{vetId}             — Favorited vets
//    ├─ favoritesAdoptPets/{petId}        — Favorited adopt pets
//    └─ favoriteAccessories/{accessId}    — Legacy favorited accessories
//
//  PublicUserProfiles/{uid}               — Public-facing user profile snapshot
//  UserPresence/{uid}                     — Online/offline + lastSeen
//
//  CardsCol/{cardId}                      — Bird/pet cards
//  CagesCol/{cageId}                      — Cages (breeding pairs)
//    └─ ChildsCol/{childId}               — Offspring inside a cage
//  ArchiveCol/{archiveId}                 — Archives
//    └─ ArchiveDetailsCol/{detailId}      — Archive detail entries
//  TrashCol/{trashId}                     — Soft-deleted items
//  BuyersCollection/{buyerId}             — Sale/buyer records
//
//  pet_ads/{adId}                         — Pet classified ads
//    ├─ viewerIDs/{uid}                   — View interactions
//    ├─ favIDs/{uid}                      — Favorite interactions
//    ├─ shareIDs/{uid}                    — Share interactions
//    ├─ callersIDs/{uid}                  — Call interactions
//    └─ chatsIDs/{uid}                    — Chat interactions
//
//  petAccessories/{accessId}              — Accessories & food products
//    ├─ viewerIDs/{uid}
//    ├─ favIDs/{uid}
//    ├─ shareIDs/{uid}
//    ├─ callersIDs/{uid}
//    └─ chatsIDs/{uid}
//
//  serviceOffers/{serviceId}              — Pet service offers
//    ├─ viewerIDs/{uid}
//    ├─ favIDs/{uid}
//    ├─ shareIDs/{uid}
//    ├─ callersIDs/{uid}
//    └─ chatsIDs/{uid}
//
//  veterinarians/{vetId}                  — Veterinarian listings
//
//  adopt_pets/{petId}                     — Pets available for adoption
//
//  Chats/{threadId}                       — Chat threads
//    └─ Messages/{msgId}                  — Chat messages
//  ChatReports/{reportId}                 — Reported chats
//
//  Orders/{orderId}                       — E-commerce orders
//    ├─ events/{eventId}                  — Order timeline events
//    └─ requests/{requestId}              — Support / return / cancel requests
//        └─ events/{eventId}              — Request timeline events
//
//  CommerceConfig/{docId}                 — Payment settings (admin-only)
//
//  MainBannersViewsCol/{bannerId}         — Banner view containers
//  HomePromoCarouselCollection/{cardId}   — Home promo carousel cards
//
//  MainKindsCollection/{kindId}           — Pet categories (kinds)
//    └─ SubKinds/{subId}                  — Sub-kinds
//        └─ SubSubKinds/{subSubId}        — Sub-sub-kinds
//            └─ Items/{itemId}            — Kind items
//
//  stories/{storyId}                      — User stories
//
//  AdminAuditLogs/{logId}                 — Audit trail (Cloud Functions only)
//
//  trGCol/{docId}                         — Internal app triggers / config
//
//  cartItems (local only, persisted on UsersCol path via CartManager)
//
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════════════

    /// Authenticated user check
    function isSignedIn() {
      return request.auth != null;
    }

    /// Current authenticated UID
    function uid() {
      return request.auth.uid;
    }

    /// The requesting user is the document owner
    function isOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    /// Read the user's profile document
    function userDoc() {
      return get(/databases/$(database)/documents/UsersCol/$(uid())).data;
    }

    /// Check if user is blocked
    function isNotBlocked() {
      let u = userDoc();
      return !(u.get('isBlocked', false) == true || u.get('blocked', false) == true);
    }

    /// Role value from profile (integer enum)
    function userRoleValue() {
      let u = userDoc();
      let rv = u.get('roleValue', null);
      return rv != null ? rv : u.get('role', 1);
    }

    /// Check if the user has admin-level role (owner=2, vet=3, moderator=4, admin=5, storemanager=6, foodmanager=7, superadmin=8)
    function isAdminRole() {
      return isSignedIn() && userRoleValue() >= 2;
    }

    /// Full admin (admin=5 or superadmin=8) OR has isAdmin/isSuperAdmin flag
    function isAdmin() {
      let u = userDoc();
      return isSignedIn() && (
        userRoleValue() >= 5 ||
        u.get('isAdmin', false) == true ||
        u.get('isSuperAdmin', false) == true
      );
    }

    /// Super admin only (roleValue == 8 OR isSuperAdmin flag)
    function isSuperAdmin() {
      let u = userDoc();
      return isSignedIn() && (
        userRoleValue() == 8 ||
        u.get('isSuperAdmin', false) == true
      );
    }

    /// Moderator or above (roleValue >= 4)
    function isModerator() {
      return isSignedIn() && userRoleValue() >= 4;
    }

    /// Store manager or food manager or admin
    function isStoreOrFoodManager() {
      let rv = userRoleValue();
      return isSignedIn() && (rv == 6 || rv == 7 || rv >= 5);
    }

    /// Owner role (breeder/shop owner, roleValue == 2)
    function isOwnerRole() {
      return isSignedIn() && userRoleValue() >= 2;
    }

    /// Validate that a write does not modify read-only system fields
    function noSystemFieldTampering() {
      let incoming = request.resource.data;
      // Block client from self-promoting
      return !(
        incoming.diff(resource.data).affectedKeys().hasAny([
          'isAdmin', 'isSuperAdmin', 'isBlocked', 'blocked',
          'role', 'roleValue', 'roleName', 'claims'
        ])
      );
    }

    /// Incoming data has required keys
    function hasAll(keys) {
      return request.resource.data.keys().hasAll(keys);
    }

    /// Field is a string with length > 0
    function isNonEmptyString(field) {
      return request.resource.data[field] is string
          && request.resource.data[field].size() > 0;
    }

    /// Timestamp field is a valid timestamp
    function isTimestamp(field) {
      return request.resource.data[field] is timestamp;
    }

    // ════════════════════════════════════════════════════════════════════════
    //  1. USERS — UsersCol/{uid}
    // ════════════════════════════════════════════════════════════════════════

    match /UsersCol/{userId} {
      // Any signed-in user can read any profile (for chat peer info, etc.)
      allow read: if isSignedIn();

      // Users can create their own profile on sign-up
      allow create: if isOwner(userId)
                    && hasAll(['ID'])
                    && request.resource.data.ID == userId;

      // Users can update their own profile but cannot change role/admin fields
      allow update: if (isOwner(userId) && noSystemFieldTampering())
                    || isAdmin();

      // Only super admins or Cloud Functions (admin SDK) can delete users
      allow delete: if isSuperAdmin();

      // ── Permissions subcollection (canonical) ──
      match /permissions/{permKey} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      // ── Legacy permissions (typo variant) ──
      match /PermisstionsCol/{permKey} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      // ── Legacy permissions (alt variant) ──
      match /PermissionsCol/{permKey} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      // ── Shipping Addresses ──
      match /Addresses/{addressId} {
        allow read, write: if isOwner(userId);
        allow read: if isAdmin();  // Admin can view for order fulfillment
      }

      // ── Payment Instruments ──
      match /paymentInstruments/{instrId} {
        allow read, write: if isOwner(userId);
        // Cloud Functions handle scrubbing via admin SDK
      }

      // ── Admin Inbox (push notifications) ──
      match /inbox/{notifId} {
        allow read: if isOwner(userId);
        // Only Cloud Functions create inbox entries
        allow create: if false;
        allow update, delete: if isOwner(userId);  // Mark read / dismiss
      }

      // ── Favorites subcollections (user-specific) ──
      match /favoritesAds/{adId} {
        allow read, write: if isOwner(userId);
      }
      match /favoritesAccessories/{accessId} {
        allow read, write: if isOwner(userId);
      }
      match /favoritesServices/{serviceId} {
        allow read, write: if isOwner(userId);
      }
      match /favoritesVets/{vetId} {
        allow read, write: if isOwner(userId);
      }
      match /favoritesAdoptPets/{petId} {
        allow read, write: if isOwner(userId);
      }
      match /favoriteAccessories/{accessId} {
        // Legacy path
        allow read, write: if isOwner(userId);
      }

      // ── Cart Items (synced under user doc) ──
      match /cartItems/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  2. PUBLIC USER PROFILES — PublicUserProfiles/{uid}
    // ════════════════════════════════════════════════════════════════════════

    match /PublicUserProfiles/{userId} {
      // Anyone signed in can read public profiles
      allow read: if isSignedIn();
      // Only Cloud Functions (syncPublicUserProfile trigger) write here
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════════
    //  3. USER PRESENCE — UserPresence/{uid}
    // ════════════════════════════════════════════════════════════════════════

    match /UserPresence/{userId} {
      // Any signed-in user can read presence (for chat online status)
      allow read: if isSignedIn();
      // Only the user themselves can update their own presence
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════
    //  4. BIRD / PET CARDS — CardsCol/{cardId}
    // ════════════════════════════════════════════════════════════════════════

    match /CardsCol/{cardId} {
      // Owner can read their own cards; admin can read all
      allow read: if isSignedIn()
                  && (resource.data.UserID == uid() || isAdmin());

      // Owner can create cards for themselves
      allow create: if isSignedIn()
                    && request.resource.data.UserID == uid()
                    && isNotBlocked();

      // Owner can update/delete their own cards; admin can manage all
      allow update, delete: if isSignedIn()
                            && (resource.data.UserID == uid() || isAdmin());
    }

    // ════════════════════════════════════════════════════════════════════════
    //  5. CAGES — CagesCol/{cageId}
    // ════════════════════════════════════════════════════════════════════════

    match /CagesCol/{cageId} {
      allow read: if isSignedIn()
                  && (resource.data.UserID == uid() || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.UserID == uid()
                    && isNotBlocked();

      allow update, delete: if isSignedIn()
                            && (resource.data.UserID == uid() || isAdmin());

      // ── Children inside a cage ──
      match /ChildsCol/{childId} {
        allow read: if isSignedIn()
                    && (get(/databases/$(database)/documents/CagesCol/$(cageId)).data.UserID == uid()
                        || isAdmin());

        allow create: if isSignedIn()
                      && request.resource.data.UserID == uid()
                      && isNotBlocked();

        allow update, delete: if isSignedIn()
                              && (resource.data.UserID == uid() || isAdmin());
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  6. ARCHIVES — ArchiveCol/{archiveId}
    // ════════════════════════════════════════════════════════════════════════

    match /ArchiveCol/{archiveId} {
      allow read: if isSignedIn()
                  && (resource.data.archiveOwnerID == uid() || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.archiveOwnerID == uid()
                    && isNotBlocked();

      allow update, delete: if isSignedIn()
                            && (resource.data.archiveOwnerID == uid() || isAdmin());

      // ── Archive Details ──
      match /ArchiveDetailsCol/{detailId} {
        allow read: if isSignedIn()
                    && (get(/databases/$(database)/documents/ArchiveCol/$(archiveId)).data.archiveOwnerID == uid()
                        || isAdmin());

        allow create: if isSignedIn()
                      && request.resource.data.UserID == uid()
                      && isNotBlocked();

        allow update, delete: if isSignedIn()
                              && (resource.data.UserID == uid() || isAdmin());
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  7. TRASH — TrashCol/{trashId}
    // ════════════════════════════════════════════════════════════════════════

    match /TrashCol/{trashId} {
      allow read: if isSignedIn()
                  && (resource.data.ownerID == uid() || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.ownerID == uid()
                    && isNotBlocked();

      allow update, delete: if isSignedIn()
                            && (resource.data.ownerID == uid() || isAdmin());
    }

    // ════════════════════════════════════════════════════════════════════════
    //  8. BUYERS — BuyersCollection/{buyerId}
    // ════════════════════════════════════════════════════════════════════════

    match /BuyersCollection/{buyerId} {
      allow read: if isSignedIn()
                  && (resource.data.UserID == uid() || isAdmin());

      allow create: if isSignedIn()
                    && request.resource.data.UserID == uid()
                    && isNotBlocked();

      allow update, delete: if isSignedIn()
                            && (resource.data.UserID == uid() || isAdmin());
    }

    // ════════════════════════════════════════════════════════════════════════
    //  9. PET ADS — pet_ads/{adId}
    // ════════════════════════════════════════════════════════════════════════

    match /pet_ads/{adId} {
      // Public ads visible to all signed-in users
      // Non-public ads visible only to owner or admin
      allow read: if isSignedIn()
                  && (
                    (resource.data.status == 1
                     && resource.data.get('isApproved', false) == true
                     && resource.data.visibility == 0)
                    || resource.data.ownerID == uid()
                    || isAdmin()
                  );

      allow create: if isSignedIn()
                    && request.resource.data.ownerID == uid()
                    && isNotBlocked();

      // Owner can update their own ads; admin/moderator can moderate any
      allow update: if isSignedIn()
                    && (resource.data.ownerID == uid() || isModerator());

      allow delete: if isSignedIn()
                    && (resource.data.ownerID == uid() || isAdmin());

      // ── Interaction subcollections ──
      match /viewerIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /favIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /shareIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /callersIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /chatsIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  10. PET ACCESSORIES — petAccessories/{accessId}
    // ════════════════════════════════════════════════════════════════════════

    match /petAccessories/{accessId} {
      // All signed-in users can browse accessories
      allow read: if isSignedIn();

      // Store/food managers or admins can create accessories
      allow create: if isSignedIn()
                    && isStoreOrFoodManager()
                    && isNotBlocked();

      // Owner of the accessory or store/food manager can update
      allow update: if isSignedIn()
                    && (resource.data.ownerID == uid() || isStoreOrFoodManager());

      // Owner or admin can delete
      allow delete: if isSignedIn()
                    && (resource.data.ownerID == uid() || isAdmin());

      // ── Interaction subcollections ──
      match /viewerIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /favIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /shareIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /callersIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /chatsIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  11. SERVICE OFFERS — serviceOffers/{serviceId}
    // ════════════════════════════════════════════════════════════════════════

    match /serviceOffers/{serviceId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.serviceOwnerID == uid()
                    && isNotBlocked();

      allow update: if isSignedIn()
                    && (resource.data.serviceOwnerID == uid() || isAdmin());

      allow delete: if isSignedIn()
                    && (resource.data.serviceOwnerID == uid() || isAdmin());

      // ── Interaction subcollections ──
      match /viewerIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /favIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /shareIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /callersIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
      match /chatsIDs/{interactorId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && interactorId == uid();
        allow delete: if isSignedIn() && interactorId == uid();
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  12. VETERINARIANS — veterinarians/{vetId}
    // ════════════════════════════════════════════════════════════════════════

    match /veterinarians/{vetId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.userID == uid()
                    && isNotBlocked();

      allow update: if isSignedIn()
                    && (resource.data.userID == uid() || isAdmin());

      allow delete: if isSignedIn()
                    && (resource.data.userID == uid() || isAdmin());
    }

    // ════════════════════════════════════════════════════════════════════════
    //  13. ADOPT PETS — adopt_pets/{petId}
    // ════════════════════════════════════════════════════════════════════════

    match /adopt_pets/{petId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.ownerID == uid()
                    && isNotBlocked();

      allow update: if isSignedIn()
                    && (resource.data.ownerID == uid() || isAdmin());

      allow delete: if isSignedIn()
                    && (resource.data.ownerID == uid() || isAdmin());
    }

    // ════════════════════════════════════════════════════════════════════════
    //  14. CHATS — Chats/{threadId}
    // ════════════════════════════════════════════════════════════════════════

    match /Chats/{threadId} {
      // Only members of the chat can read the thread
      allow read: if isSignedIn()
                  && uid() in resource.data.memberIDs;

      // Either member can create a thread; memberIDs must include the creator
      allow create: if isSignedIn()
                    && uid() in request.resource.data.memberIDs
                    && request.resource.data.memberIDs.size() == 2
                    && isNotBlocked();

      // Only members can update (e.g. lastMessage, pin, mute, bin, report)
      allow update: if isSignedIn()
                    && uid() in resource.data.memberIDs;

      // Members or admin can delete (e.g. clear thread)
      allow delete: if isSignedIn()
                    && (uid() in resource.data.memberIDs || isAdmin());

      // ── Messages subcollection ──
      match /Messages/{msgId} {
        // Only thread members can read messages
        allow read: if isSignedIn()
                    && uid() in get(/databases/$(database)/documents/Chats/$(threadId)).data.memberIDs;

        // Only thread members can send messages; senderID must be the auth user
        allow create: if isSignedIn()
                      && request.resource.data.senderID == uid()
                      && uid() in get(/databases/$(database)/documents/Chats/$(threadId)).data.memberIDs
                      && isNotBlocked();

        // Sender can update their own message (edit, mark deleted)
        // Receiver can update delivery/read status
        allow update: if isSignedIn()
                      && uid() in get(/databases/$(database)/documents/Chats/$(threadId)).data.memberIDs;

        // Only sender or admin can delete a message
        allow delete: if isSignedIn()
                      && (resource.data.senderID == uid() || isAdmin());
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  15. CHAT REPORTS — ChatReports/{reportId}
    // ════════════════════════════════════════════════════════════════════════

    match /ChatReports/{reportId} {
      // Only admins/moderators can read reports
      allow read: if isModerator();

      // Any signed-in user can create a report
      allow create: if isSignedIn() && isNotBlocked();

      // Only moderators/admins can update (review/resolve)
      allow update, delete: if isModerator();
    }

    // ════════════════════════════════════════════════════════════════════════
    //  16. ORDERS — Orders/{orderId}
    // ════════════════════════════════════════════════════════════════════════

    match /Orders/{orderId} {
      // Order owner or admin can read
      allow read: if isSignedIn()
                  && (resource.data.userId == uid() || isAdmin());

      // Orders are created ONLY by Cloud Functions (createPendingOrder)
      allow create: if false;

      // Status transitions handled by Cloud Functions (adminTransitionOrderStatus)
      // Users can only update limited fields (e.g., cancel request metadata)
      allow update: if isSignedIn()
                    && (resource.data.userId == uid() || isAdmin());

      // Only admins can delete orders
      allow delete: if isAdmin();

      // ── Order Events (timeline) ──
      match /events/{eventId} {
        allow read: if isSignedIn()
                    && (get(/databases/$(database)/documents/Orders/$(orderId)).data.userId == uid()
                        || isAdmin());
        // Created by Cloud Functions only
        allow create: if false;
        allow update, delete: if isAdmin();
      }

      // ── Order Support Requests ──
      match /requests/{requestId} {
        allow read: if isSignedIn()
                    && (get(/databases/$(database)/documents/Orders/$(orderId)).data.userId == uid()
                        || isAdmin());
        // Created by Cloud Functions (createOrderSupportRequest)
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin();

        // ── Request Events (sub-timeline) ──
        match /events/{eventId} {
          allow read: if isSignedIn()
                      && (get(/databases/$(database)/documents/Orders/$(orderId)).data.userId == uid()
                          || isAdmin());
          allow write: if false;  // Cloud Functions only
        }
      }
    }

    // ════════════════════════════════════════════════════════════════════════
    //  17. COMMERCE CONFIG — CommerceConfig/{docId}
    // ════════════════════════════════════════════════════════════════════════

    match /CommerceConfig/{docId} {
      // Cart manager reads delivery fee / payment settings
      allow read: if isSignedIn();
      // Only admins can modify commerce configuration
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════
    //  18. BANNERS — MainBannersViewsCol/{bannerId}
    // ════════════════════════════════════════════════════════════════════════

    match /MainBannersViewsCol/{bannerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════
    //  19. HOME PROMO CAROUSEL — HomePromoCarouselCollection/{cardId}
    // ════════════════════════════════════════════════════════════════════════

    match /HomePromoCarouselCollection/{cardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════
    //  20. MAIN KINDS (CATEGORIES) — MainKindsCollection/{kindId}
    // ════════════════════════════════════════════════════════════════════════

    match /MainKindsCollection/{kindId} {
      // All users can read categories
      allow read: if isSignedIn();
      // Only admins can manage categories
      allow write: if isAdmin();

      match /SubKinds/{subId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();

        match /SubSubKinds/{subSubId} {
          allow read: if isSignedIn();
          allow write: if isAdmin();

          match /Items/{itemId} {
            allow read: if isSignedIn();
            allow write: if isAdmin();
          }
        }
      }
    }

    // ── Temp migration collection ──
    match /MainKindsCollectionTemp/{kindId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════
    //  21. STORIES — stories/{storyId}
    // ════════════════════════════════════════════════════════════════════════

    match /stories/{storyId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.userID == uid()
                    && isNotBlocked();

      allow update: if isSignedIn()
                    && (resource.data.userID == uid() || isAdmin());

      allow delete: if isSignedIn()
                    && (resource.data.userID == uid() || isAdmin());
    }

    // ════════════════════════════════════════════════════════════════════════
    //  22. ADMIN AUDIT LOGS — AdminAuditLogs/{logId}
    // ════════════════════════════════════════════════════════════════════════

    match /AdminAuditLogs/{logId} {
      // Only super admins can read audit logs
      allow read: if isSuperAdmin();
      // Written exclusively by Cloud Functions (admin SDK)
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════════════════
    //  23. INTERNAL TRIGGERS — trGCol/{docId}
    // ════════════════════════════════════════════════════════════════════════

    match /trGCol/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════
    //  24. CATCH-ALL — Deny everything else by default
    // ════════════════════════════════════════════════════════════════════════
    //  Firestore denies unmatched paths by default, but we add an explicit
    //  match to document intent and prevent accidental open access.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
