# QIB payment runtime configuration (Firebase Functions v2)
# Copy to .env.local (local emulator) or .env.production (deploy), then fill real values.

# Required: choose one mode only
QIB_MODE=test

# Optional: set false only during controlled App Check rollout/debug.
QIB_ENFORCE_APP_CHECK=true

# Test credentials (used when QIB_MODE=test)
QIB_GATEWAY_ID_TEST=
QIB_SECRET_KEY_TEST=

# Live credentials (used when QIB_MODE=live)
QIB_GATEWAY_ID_LIVE=
QIB_SECRET_KEY_LIVE=

# Legacy mobile SDK compatibility:
# true  => return gateway/secret in createQibSession response (current app SDK requirement).
# false => block createQibSession until secure hosted/tokenized QIB payload is implemented.
QIB_ALLOW_LEGACY_CLIENT_BOOTSTRAP=true

# Required secure verification endpoint
QIB_VERIFY_URL=

# Optional bearer key for verification endpoint
QIB_VERIFY_API_KEY=

# Temporary fallback:
# true  => if QIB_VERIFY_URL is missing, use SDK callback status from client payload.
# false => strict mode; verify endpoint is mandatory.
QIB_ALLOW_CLIENT_ONLY_VERIFICATION=true

# Optional verification retry backoff tuning
QIB_VERIFY_RETRY_BASE_SECONDS=120
QIB_VERIFY_RETRY_MAX_SECONDS=3600
