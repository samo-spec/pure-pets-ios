- (void)pp_preselectMethodForInstrument:(UserPaymentInstrument *)instrument {
    NSString *normalizedID = PPPaymentFormNormalizedMethodID(instrument.methodID);
    self.selectedMethod = instrument.method ?: [PaymentMethod methodForID:normalizedID];

    for (PPMethodPickerCard *card in _methodCards) {
        BOOL match = [card.method.methodID isEqualToString:normalizedID];
        [card setSelected:match animated:NO];
    }
}

- (void)pp_prefillFieldsWithInstrument:(UserPaymentInstrument *)instrument {
    NSDictionary *original = instrument.originalData ?: @{};
    for (NSString *key in original) {
        UITextField *tf = self.fieldsByTag[key];
        if (tf) {
            tf.text = original[key];
            // Trigger floating label
            PPFormFieldView *field = (PPFormFieldView *)tf.superview;
            if ([field isKindOfClass:[PPFormFieldView class]]) {
                [field prefillValue:original[key]];
            }
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// MARK: - Keyboard Handling
// ─────────────────────────────────────────────────────────────────────────────

- (void)pp_registerKeyboardNotifications {
    [[NSNotificationCenter defaultCenter] addObserver:self
                                             selector:@selector(pp_keyboardWillShow:)
                                                 name:UIKeyboardWillShowNotification
                                               object:nil];
    [[NSNotificationCenter defaultCenter] addObserver:self
                                             selector:@selector(pp_keyboardWillHide:)
                                                 name:UIKeyboardWillHideNotification
                                               object:nil];
}

- (void)pp_keyboardWillShow:(NSNotification *)note {
    CGRect kbFrame = [note.userInfo[UIKeyboardFrameEndUserInfoKey] CGRectValue];
    CGFloat kbH    = kbFrame.size.height;
    NSTimeInterval dur = [note.userInfo[UIKeyboardAnimationDurationUserInfoKey] doubleValue];
    UIViewAnimationCurve curve = [note.userInfo[UIKeyboardAnimationCurveUserInfoKey] integerValue];

    [UIView animateWithDuration:dur delay:0 options:(curve << 16) animations:^{
        self.scrollView.contentInset = UIEdgeInsetsMake(0, 0, kbH + 20, 0);
        self.scrollView.scrollIndicatorInsets = self.scrollView.contentInset;
    } completion:nil];

    // Auto-scroll to the active field
    UIView *active = [self pp_findFirstResponderIn:self.formFieldsStack];
    if (active) {
        CGRect rect = [active convertRect:active.bounds toView:self.scrollView];
        rect = CGRectInset(rect, 0, -30);
        [self.scrollView scrollRectToVisible:rect animated:YES];
    }
}

- (void)pp_keyboardWillHide:(NSNotification *)note {
    NSTimeInterval dur = [note.userInfo[UIKeyboardAnimationDurationUserInfoKey] doubleValue];
    UIViewAnimationCurve curve = [note.userInfo[UIKeyboardAnimationCurveUserInfoKey] integerValue];

    [UIView animateWithDuration:dur delay:0 options:(curve << 16) animations:^{
        self.scrollView.contentInset = UIEdgeInsetsZero;
        self.scrollView.scrollIndicatorInsets = UIEdgeInsetsZero;
    } completion:nil];
}

- (UIView *)pp_findFirstResponderIn:(UIView *)view {
    if ([view isFirstResponder]) return view;
    for (UIView *sub in view.subviews) {
        UIView *found = [self pp_findFirstResponderIn:sub];
        if (found) return found;
    }
    return nil;
}

// ─────────────────────────────────────────────────────────────────────────────
// MARK: - UITextFieldDelegate
// ─────────────────────────────────────────────────────────────────────────────

- (BOOL)textFieldShouldReturn:(UITextField *)textField {
    // Move to next field or dismiss
    NSArray<NSString *> *orderedTags = self.fieldsByTag.allKeys;
    NSInteger idx = NSNotFound;
    for (NSInteger i = 0; i < orderedTags.count; i++) {
        if (self.fieldsByTag[orderedTags[i]] == textField) {
            idx = i;
            break;
        }
    }
    if (idx != NSNotFound && idx + 1 < (NSInteger)orderedTags.count) {
        [self.fieldsByTag[orderedTags[idx + 1]] becomeFirstResponder];
    } else {
        [textField resignFirstResponder];
    }
    return YES;
}

@end


