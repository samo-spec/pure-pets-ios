@interface PPFormFieldView : UIView
@property (nonatomic, strong) UITextField *textField;
@property (nonatomic, strong) UILabel     *floatingLabel;
@property (nonatomic, strong) UIImageView *iconView;
@property (nonatomic, copy)   NSString    *tag;
- (instancetype)initWithTag:(NSString *)tag
                placeholder:(NSString *)placeholder
                       icon:(NSString *)sfSymbol
               keyboardType:(UIKeyboardType)keyboard
                   isSecure:(BOOL)secure;
@end

@implementation PPFormFieldView

- (instancetype)initWithTag:(NSString *)aTag
                placeholder:(NSString *)placeholder
                       icon:(NSString *)sfSymbol
               keyboardType:(UIKeyboardType)keyboard
                   isSecure:(BOOL)secure {
    self = [super initWithFrame:CGRectZero];
    if (!self) return nil;
    self.tag = 0;
    _tag = [aTag copy];
    self.translatesAutoresizingMaskIntoConstraints = NO;
    self.backgroundColor = [AppForgroundColr colorWithAlphaComponent:0.85];
    self.layer.cornerRadius = 16.0;
    self.layer.cornerCurve  = kCACornerCurveContinuous;
    self.layer.borderWidth  = 1.0;
    self.layer.borderColor  = [UIColor colorWithWhite:1.0 alpha:0.10].CGColor;

    // Icon
    _iconView = [[UIImageView alloc] initWithImage:[UIImage systemImageNamed:sfSymbol]];
    _iconView.translatesAutoresizingMaskIntoConstraints = NO;
    _iconView.tintColor   = AppPrimaryClr;
    _iconView.contentMode = UIViewContentModeScaleAspectFit;
    [self addSubview:_iconView];

    // Floating label
    _floatingLabel = [[UILabel alloc] init];
    _floatingLabel.translatesAutoresizingMaskIntoConstraints = NO;
    _floatingLabel.text      = placeholder;
    _floatingLabel.font      = [GM MidFontWithSize:11];
    _floatingLabel.textColor = AppSecondaryTextClr;
    _floatingLabel.alpha     = 0.0;
    [self addSubview:_floatingLabel];

    // Text field
    _textField = [[UITextField alloc] init];
    _textField.translatesAutoresizingMaskIntoConstraints = NO;
    _textField.placeholder    = placeholder;
    _textField.font           = [GM MidFontWithSize:15];
    _textField.textColor      = UIColor.labelColor;
    _textField.keyboardType   = keyboard;
    _textField.secureTextEntry = secure;
    _textField.autocorrectionType   = UITextAutocorrectionTypeNo;
    _textField.textAlignment  = (GM.setAligment == NSTextAlignmentRight)
                                 ? NSTextAlignmentRight : NSTextAlignmentLeft;
    [self addSubview:_textField];

    [_textField addTarget:self action:@selector(_editingChanged) forControlEvents:UIControlEventEditingChanged];
    [_textField addTarget:self action:@selector(_editingBegan)   forControlEvents:UIControlEventEditingDidBegin];
    [_textField addTarget:self action:@selector(_editingEnded)   forControlEvents:UIControlEventEditingDidEnd];

    // Layout
    [NSLayoutConstraint activateConstraints:@[
        [self.heightAnchor constraintEqualToConstant:60.0],

        [_iconView.leadingAnchor  constraintEqualToAnchor:self.leadingAnchor constant:14],
        [_iconView.centerYAnchor  constraintEqualToAnchor:self.centerYAnchor],
        [_iconView.widthAnchor    constraintEqualToConstant:22],
        [_iconView.heightAnchor   constraintEqualToConstant:22],

        [_floatingLabel.leadingAnchor  constraintEqualToAnchor:_iconView.trailingAnchor constant:10],
        [_floatingLabel.trailingAnchor constraintEqualToAnchor:self.trailingAnchor constant:-14],
        [_floatingLabel.topAnchor      constraintEqualToAnchor:self.topAnchor constant:8],

        [_textField.leadingAnchor  constraintEqualToAnchor:_iconView.trailingAnchor constant:10],
        [_textField.trailingAnchor constraintEqualToAnchor:self.trailingAnchor constant:-14],
        [_textField.bottomAnchor   constraintEqualToAnchor:self.bottomAnchor constant:-8],
        [_textField.topAnchor      constraintEqualToAnchor:_floatingLabel.bottomAnchor constant:2],
    ]];

    return self;
}

- (void)_editingBegan {
    [self _showFloatingLabel:YES];
    [UIView animateWithDuration:0.2 animations:^{
        self.layer.borderColor = [AppPrimaryClr colorWithAlphaComponent:0.5].CGColor;
    }];
}

- (void)_editingEnded {
    if (self.textField.text.length == 0) [self _showFloatingLabel:NO];
    [UIView animateWithDuration:0.2 animations:^{
        self.layer.borderColor = [UIColor colorWithWhite:1.0 alpha:0.10].CGColor;
    }];
}

- (void)_editingChanged {
    [self _showFloatingLabel:self.textField.text.length > 0 || self.textField.isFirstResponder];
}

- (void)_showFloatingLabel:(BOOL)show {
    [UIView animateWithDuration:0.22 delay:0 options:UIViewAnimationOptionCurveEaseOut animations:^{
        self.floatingLabel.alpha = show ? 1.0 : 0.0;
    } completion:nil];
}

- (void)prefillValue:(NSString *)value {
    self.textField.text = value;
    if (value.length > 0) [self _showFloatingLabel:YES];
}

@end

