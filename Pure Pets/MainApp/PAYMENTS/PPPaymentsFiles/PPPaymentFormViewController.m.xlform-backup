// ─────────────────────────────────────────────────────────────────────────────
// MARK: - Method Picker (Add mode)
// ─────────────────────────────────────────────────────────────────────────────

- (void)pp_buildMethodPicker {
    // Section label
    UILabel *sectionLabel = [[UILabel alloc] init];
    sectionLabel.translatesAutoresizingMaskIntoConstraints = NO;
    sectionLabel.text = kLang(@"PaymentMethodTitle");
    sectionLabel.font = [GM boldFontWithSize:17];
    sectionLabel.textColor = UIColor.labelColor;
    [_mainStack addArrangedSubview:sectionLabel];

    // Horizontal scroll of method cards
    _methodScroll = [[UIScrollView alloc] init];
    _methodScroll.translatesAutoresizingMaskIntoConstraints = NO;
    _methodScroll.showsHorizontalScrollIndicator = NO;
    _methodScroll.clipsToBounds = NO;
    [_methodScroll.heightAnchor constraintEqualToConstant:140].active = YES;

    _methodStack = [[UIStackView alloc] init];
    _methodStack.translatesAutoresizingMaskIntoConstraints = NO;
    _methodStack.axis = UILayoutConstraintAxisHorizontal;
    _methodStack.spacing = 12;
    _methodStack.alignment = UIStackViewAlignmentFill;
    [_methodScroll addSubview:_methodStack];

    [NSLayoutConstraint activateConstraints:@[
        [_methodStack.topAnchor      constraintEqualToAnchor:_methodScroll.topAnchor],
        [_methodStack.leadingAnchor  constraintEqualToAnchor:_methodScroll.leadingAnchor],
        [_methodStack.trailingAnchor constraintEqualToAnchor:_methodScroll.trailingAnchor],
        [_methodStack.bottomAnchor   constraintEqualToAnchor:_methodScroll.bottomAnchor],
        [_methodStack.heightAnchor   constraintEqualToAnchor:_methodScroll.heightAnchor],
    ]];

    for (PaymentMethod *method in self.availableMethods) {
        PPMethodPickerCard *card = [[PPMethodPickerCard alloc] initWithMethod:method];
        UITapGestureRecognizer *tap = [[UITapGestureRecognizer alloc] initWithTarget:self
                                                                              action:@selector(pp_methodCardTapped:)];
        [card addGestureRecognizer:tap];
        [_methodStack addArrangedSubview:card];
        [_methodCards addObject:card];
    }

    [_mainStack addArrangedSubview:_methodScroll];
}

- (void)pp_methodCardTapped:(UITapGestureRecognizer *)gesture {
    PPMethodPickerCard *tapped = (PPMethodPickerCard *)gesture.view;
    if (!tapped || ![tapped isKindOfClass:[PPMethodPickerCard class]]) return;
    [self pp_selectMethod:tapped.method animated:YES];
}

- (void)pp_selectMethod:(PaymentMethod *)method animated:(BOOL)animated {
    self.selectedMethod = method;
    _expanded = YES;

    // Update picker highlights
    for (PPMethodPickerCard *card in _methodCards) {
        BOOL match = [card.method.methodID isEqualToString:method.methodID];
        [card setSelected:match animated:animated];
    }

    [self pp_buildFieldsForMethod:method];
    [self.delegate expandToLargeDetent:_expanded];
}

