// ─────────────────────────────────────────────────────────────────────────────
// MARK: - Build Fields For Method
// ─────────────────────────────────────────────────────────────────────────────

- (void)pp_buildFieldsForMethod:(PaymentMethod *)method {
    // Clear existing
    for (UIView *v in _formFieldsStack.arrangedSubviews) {
        [v removeFromSuperview];
    }
    [_fieldsByTag removeAllObjects];
    _applePayInfoLabel.hidden = YES;
    _formFieldsStack.hidden   = NO;
    _formContainerView.hidden = NO;

    NSString *mid = PPPaymentFormNormalizedMethodID(method.methodID);

    if (PPPaymentFormUsesCardFields(mid)) {
        // Credit/Debit Card (QIB)
        [self pp_addField:@"cardNumber" placeholder:kLang(@"CardNumberPlaceholder")
                     icon:@"creditcard" keyboard:UIKeyboardTypeNumberPad secure:NO];
        [self pp_addField:@"expiry" placeholder:kLang(@"ExpiryDatePlaceholder")
                     icon:@"calendar" keyboard:UIKeyboardTypeNumbersAndPunctuation secure:NO];
        [self pp_addField:@"cvv" placeholder:kLang(@"CVVPlaceholder")
                     icon:@"lock.fill" keyboard:UIKeyboardTypeNumberPad secure:YES];

    } else if ([mid isEqualToString:@"applepay"]) {
        // Apple Pay — no form fields
        _formFieldsStack.hidden   = YES;
        _applePayInfoLabel.hidden = NO;

    } else if ([mid isEqualToString:@"ooredoo"]) {
        [self pp_addField:@"ooredooNumber" placeholder:kLang(@"OoredooWalletNumberPlaceholder")
                     icon:@"phone.fill" keyboard:UIKeyboardTypePhonePad secure:NO];

    } else if ([mid isEqualToString:@"naps"] || [mid isEqualToString:@"qnb"]) {
        [self pp_addField:@"qnbAccount" placeholder:kLang(@"QNBAccountPlaceholder")
                     icon:@"banknote.fill" keyboard:UIKeyboardTypeNumberPad secure:NO];
        [self pp_addField:@"qnbOtp" placeholder:kLang(@"QNBOTPPlaceholder")
                     icon:@"key.fill" keyboard:UIKeyboardTypeNumberPad secure:YES];

    } else if ([mid isEqualToString:@"cash"]) {
        [self pp_addField:@"cashNote" placeholder:kLang(@"DeliveryNotePlaceholder")
                     icon:@"note.text" keyboard:UIKeyboardTypeDefault secure:NO];
    }

    // Animate in
    _formContainerView.alpha     = 0.0;
    _formContainerView.transform = CGAffineTransformMakeTranslation(0, 16);
    [UIView animateWithDuration:0.4
                          delay:0.05
         usingSpringWithDamping:0.85
          initialSpringVelocity:0.2
                        options:UIViewAnimationOptionCurveEaseOut
                     animations:^{
        self.formContainerView.alpha     = 1.0;
        self.formContainerView.transform = CGAffineTransformIdentity;
    } completion:nil];
}

- (void)pp_addField:(NSString *)tag
        placeholder:(NSString *)placeholder
               icon:(NSString *)sfSymbol
           keyboard:(UIKeyboardType)keyboard
             secure:(BOOL)secure {

    PPFormFieldView *field = [[PPFormFieldView alloc] initWithTag:tag
                                                      placeholder:placeholder
                                                             icon:sfSymbol
                                                     keyboardType:keyboard
                                                         isSecure:secure];
    field.textField.delegate = self;
    [_formFieldsStack addArrangedSubview:field];
    _fieldsByTag[tag] = field.textField;
}

