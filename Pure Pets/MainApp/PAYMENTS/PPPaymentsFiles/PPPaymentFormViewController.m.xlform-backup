- (void)setSelected:(BOOL)selected animated:(BOOL)animated;
@end

@implementation PPMethodPickerCard

- (instancetype)initWithMethod:(PaymentMethod *)method {
    self = [super initWithFrame:CGRectZero];
    if (!self) return nil;
    _method = method;
    _isSelectedMethod = NO;
    self.translatesAutoresizingMaskIntoConstraints = NO;
    self.backgroundColor   = [AppForgroundColr colorWithAlphaComponent:0.85];
    self.layer.cornerRadius = 20.0;
    self.layer.cornerCurve  = kCACornerCurveContinuous;
    self.layer.borderWidth  = 1.5;
    self.layer.borderColor  = [UIColor colorWithWhite:1.0 alpha:0.12].CGColor;

    // Icon
    UIImage *icon = [UIImage imageNamed:method.iconName]
                    ?: [UIImage systemImageNamed:@"creditcard.fill"];
    _iconView = [[UIImageView alloc] initWithImage:icon];
    _iconView.translatesAutoresizingMaskIntoConstraints = NO;
    _iconView.contentMode = UIViewContentModeScaleAspectFit;
    _iconView.tintColor   = AppPrimaryClr;
    [self addSubview:_iconView];

    _titleLabel = [[UILabel alloc] init];
    _titleLabel.translatesAutoresizingMaskIntoConstraints = NO;
    _titleLabel.text  = method.displayName;
    _titleLabel.font  = [GM boldFontWithSize:13];
    _titleLabel.textColor = UIColor.labelColor;
    _titleLabel.numberOfLines = 2;
    [self addSubview:_titleLabel];

    _subtitleLabel = [[UILabel alloc] init];
    _subtitleLabel.translatesAutoresizingMaskIntoConstraints = NO;
    _subtitleLabel.text  = method.methodDescription ?: @"";
    _subtitleLabel.font  = [GM MidFontWithSize:10];
    _subtitleLabel.textColor = UIColor.secondaryLabelColor;
    _subtitleLabel.numberOfLines = 2;
    [self addSubview:_subtitleLabel];

    _checkmarkView = [[UIImageView alloc] initWithImage:[UIImage systemImageNamed:@"checkmark.circle.fill"]];
    _checkmarkView.translatesAutoresizingMaskIntoConstraints = NO;
    _checkmarkView.tintColor = AppPrimaryClr;
    _checkmarkView.alpha = 0.0;
    [self addSubview:_checkmarkView];

    [NSLayoutConstraint activateConstraints:@[
        [self.widthAnchor  constraintEqualToConstant:140],
        [self.heightAnchor constraintEqualToConstant:130],

        [_iconView.topAnchor      constraintEqualToAnchor:self.topAnchor constant:14],
        [_iconView.leadingAnchor  constraintEqualToAnchor:self.leadingAnchor constant:14],
        [_iconView.widthAnchor    constraintEqualToConstant:32],
        [_iconView.heightAnchor   constraintEqualToConstant:32],

        [_checkmarkView.topAnchor     constraintEqualToAnchor:self.topAnchor constant:12],
        [_checkmarkView.trailingAnchor constraintEqualToAnchor:self.trailingAnchor constant:-12],
        [_checkmarkView.widthAnchor   constraintEqualToConstant:20],
        [_checkmarkView.heightAnchor  constraintEqualToConstant:20],

        [_titleLabel.topAnchor      constraintEqualToAnchor:_iconView.bottomAnchor constant:10],
        [_titleLabel.leadingAnchor  constraintEqualToAnchor:self.leadingAnchor constant:14],
        [_titleLabel.trailingAnchor constraintEqualToAnchor:self.trailingAnchor constant:-14],

        [_subtitleLabel.topAnchor      constraintEqualToAnchor:_titleLabel.bottomAnchor constant:4],
        [_subtitleLabel.leadingAnchor  constraintEqualToAnchor:self.leadingAnchor constant:14],
        [_subtitleLabel.trailingAnchor constraintEqualToAnchor:self.trailingAnchor constant:-14],
    ]];

    return self;
}

- (void)setSelected:(BOOL)selected animated:(BOOL)animated {
    _isSelectedMethod = selected;
    void (^changes)(void) = ^{
        self.layer.borderColor = selected
            ? [AppPrimaryClr colorWithAlphaComponent:0.7].CGColor
            : [UIColor colorWithWhite:1.0 alpha:0.12].CGColor;
        self.layer.borderWidth = selected ? 2.0 : 1.5;
        self.checkmarkView.alpha = selected ? 1.0 : 0.0;
        self.transform = selected ? CGAffineTransformMakeScale(1.03, 1.03) : CGAffineTransformIdentity;
    };

    if (animated) {
        [UIView animateWithDuration:0.45
                              delay:0
             usingSpringWithDamping:0.70
              initialSpringVelocity:0.3
                            options:UIViewAnimationOptionCurveEaseOut
                         animations:changes
                         completion:nil];
    } else {
        changes();
    }
}

@end

