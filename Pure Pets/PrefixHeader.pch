// Define logging levels
typedef NS_ENUM(NSInteger, LogLevel) {
    LogLevelNone = 0,
    LogLevelError = 1,
    LogLevelWarning = 2,
    LogLevelInfo = 3,
    LogLevelDebug = 4,
    LogLevelVerbose = 5
};

// Global log level (set this based on build configuration)
#ifdef DEBUG
    static LogLevel currentLogLevel = LogLevelDebug;
#else
    static LogLevel currentLogLevel = LogLevelWarning;
#endif

// Logging macros
#define LOG_ERROR(format, ...) if (currentLogLevel >= LogLevelError) NSLog(@"[ERROR] " format, ##__VA_ARGS__)
#define LOG_WARN(format, ...) if (currentLogLevel >= LogLevelWarning) NSLog(@"[WARN] " format, ##__VA_ARGS__)
#define LOG_INFO(format, ...) if (currentLogLevel >= LogLevelInfo) NSLog(@"[INFO] " format, ##__VA_ARGS__)
#define LOG_DEBUG(format, ...) if (currentLogLevel >= LogLevelDebug) NSLog(@"[DEBUG] " format, ##__VA_ARGS__)
#define LOG_VERBOSE(format, ...) if (currentLogLevel >= LogLevelVerbose) NSLog(@"[VERBOSE] " format, ##__VA_ARGS__)

// Emoji versions (more visual)
#define LOG_EMOJI_ERROR(format, ...) LOG_ERROR(@"❌ " format, ##__VA_ARGS__)
#define LOG_EMOJI_WARN(format, ...) LOG_WARN(@"⚠️ " format, ##__VA_ARGS__)
#define LOG_EMOJI_INFO(format, ...) LOG_INFO(@"ℹ️ " format, ##__VA_ARGS__)
#define LOG_EMOJI_DEBUG(format, ...) LOG_DEBUG(@"🐛 " format, ##__VA_ARGS__)
#define LOG_EMOJI_VERBOSE(format, ...) LOG_VERBOSE(@"🔍 " format, ##__VA_ARGS__)

// In Helpers.h
static inline NSString *PPFillValueFor(id primary, id fallback) {
    // Ensure strings only, strip NSNull
    NSString *p = ([primary isKindOfClass:NSString.class] ? primary : nil);
    NSString *f = ([fallback isKindOfClass:NSString.class] ? fallback : nil);
    if (p.length) return p;   // ✅ prefer primary if non-empty
    else return f;   // ✅ else fallback
   // return nil;               // ❌ nothing valid
}

// Small helpers
static inline NSString *PPJoinNames(NSString *first, NSString *last) {
    if (first.length && last.length) return [NSString stringWithFormat:@"%@ %@", first, last];
    return first.length ? first : (last.length ? last : @"");
}


// Safe number
static inline NSNumber *PPSafeNumber(id v) {
    return [v isKindOfClass:[NSNumber class]] ? v : nil;
}

// Safe integer
static inline NSInteger PPSafeInteger(id v) {
    return [v isKindOfClass:[NSNumber class]] ? [v integerValue] : 0;
}

// New helper for XLForm numeric fields
static inline NSInteger PPSafeFormInteger(id v) {
    if ([v isKindOfClass:[XLFormOptionsObject class]]) {
        return [((XLFormOptionsObject *)v).formValue integerValue];
    } else if ([v isKindOfClass:[NSNumber class]]) {
        return [(NSNumber *)v integerValue];
    } else if ([v isKindOfClass:[NSString class]]) {
        return [(NSString *)v integerValue];
    }
    
    return 0; // default
}

typedef NS_ENUM(NSInteger, PPMainSectionInset) {
    PPMainSectionInsetForCardLayout,
    PPMainSectionInsetForOneUILayout,
 };


// MARK: Padding and Inset PP IOS26.0
#define PP_Padding     16
// Returns 0.0 on iOS 26.0+, otherwise 12.0
#define PP_IOS26_Padding  \
({ \
    CGFloat _val = 12.0; \
    if (@available(iOS 26.0, *)) { \
        _val = 0.0; \
    } \
    _val; \
})

// Returns 12.0 on iOS 26.0+, otherwise 16.0
#define PP_IOS26_Inset  \
({ \
    CGFloat _val = 12.0; \
    if (@available(iOS 26.0, *)) { \
        _val = 12.0; \
    } \
    _val; \
})

// Safe double
static inline double PPSafeDouble(id v) {
    return [v isKindOfClass:[NSNumber class]] ? [v doubleValue] : 0.0;
}

// Safe date
static inline NSDate *PPSafeDate(id v) {
    return [v isKindOfClass:[NSDate class]] ? v : nil;
}
 
// Safe dictionary
static inline NSDictionary *PPSafeDict(id v) {
    return [v isKindOfClass:[NSDictionary class]] ? v : @{};
}

// Safe UUID joiner
static inline NSString *UUIDJoin(NSString *string) {
    return [NSString stringWithFormat:@"%@-%@",
            string ?: @"",
            [[NSUUID UUID] UUIDString]];
}

/// Universal safe integer extractor
static inline NSInteger PPSafeIntegerUniversal(id v) {
    if (!v || v == [NSNull null]) return 0;
    
    // XLFormOptionsObject case
    if ([v isKindOfClass:NSClassFromString(@"XLFormOptionsObject")]) {
        id formValue = [v valueForKey:@"formValue"];
        if ([formValue respondsToSelector:@selector(integerValue)]) {
            return [formValue integerValue];
        }
    }
    
    // NSNumber / NSString fallback
    if ([v respondsToSelector:@selector(integerValue)]) {
        return [v integerValue];
    }
    
    return 0;
}

#define PPTotalBarHeight \
({ \
    CGFloat _statusH = 0; \
    if (@available(iOS 13.0, *)) { \
        UIWindow *win = UIApplication.sharedApplication.windows.firstObject; \
        UIStatusBarManager *mgr = win.windowScene.statusBarManager; \
        _statusH = mgr.statusBarFrame.size.height; \
    } else { \
        _statusH = UIApplication.sharedApplication.statusBarFrame.size.height; \
    } \
    CGFloat _navH = 44.0; \
    UIViewController *_rootVC = UIApplication.sharedApplication.keyWindow.rootViewController; \
    UINavigationController *_nav = (_rootVC && [_rootVC isKindOfClass:UINavigationController.class]) ? \
                                   (UINavigationController *)_rootVC : \
                                   _rootVC.navigationController; \
    if (_nav && !_nav.navigationBar.hidden) { \
        _navH = _nav.navigationBar.frame.size.height; \
    } \
    (_statusH + _navH); \
})


static inline UIViewController * _Nullable PPGetTopMostViewController(void) {
    UIViewController *root = UIApplication.sharedApplication.keyWindow.rootViewController;
    return root;
}
 

// Convert anything into NSURL safely
static inline NSURL * _Nullable PPSafeURL(id value) {
    if (!value || value == (id)[NSNull null]) return nil;

    // If it's already NSURL, return directly
    if ([value isKindOfClass:[NSURL class]]) {
        return (NSURL *)value;
    }

    // If it's NSString, try to build NSURL
    if ([value isKindOfClass:[NSString class]]) {
        NSString *s = [(NSString *)value stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
        if (s.length == 0) return nil;
        NSURL *u = [NSURL URLWithString:s];
        return u;
    }

    // If it's NSNumber, convert to string
    if ([value isKindOfClass:[NSNumber class]]) {
        NSString *s = [(NSNumber *)value stringValue];
        NSURL *u = [NSURL URLWithString:s];
        return u;
    }

    // Fallback: try description
    if ([value respondsToSelector:@selector(description)]) {
        NSString *s = [[value description] stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
        if (s.length > 0) {
            NSURL *u = [NSURL URLWithString:s];
            return u;
        }
    }

    return nil;
}


// دالة لإرجاع نصف قطر الزوايا في الشاشة تقريبًا
static inline CGFloat PPScreenCornerRadius(void) {
    UIWindow *window = UIApplication.sharedApplication.windows.firstObject;
    UIEdgeInsets safeAreaInsets = window.safeAreaInsets;

    // إذا كان هناك مساحة آمنة من الأعلى أو من الجانب الأيسر، فهذا يعني أن الشاشة بها زوايا مستديرة
    CGFloat cornerRadius = MIN(safeAreaInsets.top, safeAreaInsets.left);
    
    return cornerRadius;
}


