NS_ASSUME_NONNULL_BEGIN

static inline BOOL PPIOS26(void) {
    if (@available(iOS 26.0, *)) return YES;
    return NO;
}

static inline UIColor *AppBageColor(void)
{
    return [UIColor colorWithDynamicProvider:^UIColor *(UITraitCollection *tc) {
        if (tc.userInterfaceStyle == UIUserInterfaceStyleDark) {
            return [UIColor colorWithRed:0.11 green:0.11 blue:0.12 alpha:1.0];
        }
        return [UIColor colorWithRed:0.969 green:0.961 blue:0.949 alpha:1.0];
    }];
}



static inline UIColor *PPBackgroundColorForIOS26(UIColor *fallbackColor) {
    UIColor *ios26Color = [AppBackgroundClr colorWithAlphaComponent:1.0];
    return PPIOS26() ? ios26Color : (fallbackColor ?: ios26Color);
}

static inline NSString *PPSafeString(id v) {
    return [v isKindOfClass:NSString.class] ? v : @"";
}

static inline NSArray *PPSafeArray(id v) {
    return [v isKindOfClass:NSArray.class] ? v : @[];
}


static inline UIImage *PPSYSImage(id _Nonnull v) { return [UIImage systemImageNamed:v]; }
static inline UIImage *PPImage(id _Nonnull v) { return [UIImage imageNamed:v]; }
static inline NSString *PPStringOrNil(id v) { return [v isKindOfClass:NSString.class] ? v : nil; }
static inline NSURL *PPURLOrNil(id v) {
    NSString *s = PPStringOrNil(v);
    return s.length ? [NSURL URLWithString:s] : nil;
}


